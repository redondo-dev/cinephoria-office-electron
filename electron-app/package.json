{
  "name": "cinephoria-office-electron",
  "version": "1.0.0",
  "description": "Application bureautique Cinéphoria",
  "main": "src/main/main.js",
  "author": "Reda Riad <riad.reda.fethi@gmail.com>",
  "scripts": {
    "start": "electron .",
    "dev": "electron . --dev",
    "build": "electron-builder",
    "build:win": "electron-builder --win",
    "build:mac": "electron-builder --mac",
    "build:linux": "electron-builder --linux",
    "watch": "nodemon --exec electron .",
    "postinstall": "electron-builder install-app-deps"
  },
  "devDependencies": {
    "electron": "^39.0.0",
    "electron-builder": "^26.0.12",
    "nodemon": "^3.0.0"
  },
  "dependencies": {
    "jspdf": "^3.0.3"
  },
  "build": {
    "appId": "com.cinephoria.office",
    "productName": "Cinephoria Office",
     "copyright": "Copyright © 2026 Reda Riad",
    "directories": {
      "output": "dist"
    },
    "files": [
      "src/**/*",
      "package.json"
    ],
    "win": {
      "target": "nsis"
    },
    "nsis": {
      "oneClick": false,
      "allowToChangeInstallationDirectory": true
    }
  }
}
